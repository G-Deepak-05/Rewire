# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME=Rewire
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
API_PREFIX=/api/v1

# ─── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=supersecretkey-change-in-production-min-32chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://rewire:rewire@localhost:5432/rewire

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6380/0

# ─── Celery ───────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6380/1
CELERY_RESULT_BACKEND=redis://localhost:6380/2

# ─── AI / LLM ────────────────────────────────────────────────────────────────
# LiteLLM uses OPENROUTER_API_KEY env var automatically
OPENROUTER_API_KEY=sk-or-v1-your-key-here
LLM_MODEL=openrouter/google/gemini-2.5-flash
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ─── Email / Mailpit ──────────────────────────────────────────────────────────
MAILPIT_HOST=localhost
MAILPIT_PORT=1025
EMAIL_FROM=noreply@rewire.local

# ─── Monitoring ───────────────────────────────────────────────────────────────
PROMETHEUS_ENABLED=true
